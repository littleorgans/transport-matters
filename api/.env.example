# manicure runtime configuration
#
# All env vars use the MANICURE_ prefix. Copy this file to `.env` and
# uncomment what you need. Flags passed to `manicure start` take
# precedence.

# MANICURE_APP_NAME=manicure
# MANICURE_DEBUG=true
# MANICURE_LOG_JSON=false

# MANICURE_PROXY_PORT=8787
# MANICURE_WEB_PORT=8788
# MANICURE_STORAGE_DIR=~/.manicure
