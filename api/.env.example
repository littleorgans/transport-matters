# Transport Matters runtime configuration
#
# All env vars use the TRANSPORT_MATTERS_ prefix. This file is a shell export
# reference only. The app does not load `.env` files. Flags passed to
# `transport-matters start` take precedence.

# TRANSPORT_MATTERS_APP_NAME=Transport Matters
# TRANSPORT_MATTERS_DEBUG=true
# TRANSPORT_MATTERS_LOG_JSON=false

# TRANSPORT_MATTERS_PROXY_PORT=8787
# TRANSPORT_MATTERS_WEB_PORT=8788
# TRANSPORT_MATTERS_STORAGE_DIR=~/.transport-matters

# Database config lives in ~/.transport-matters/settings.toml. Copy settings.example.toml.
# Env overrides are still supported:
# TRANSPORT_MATTERS_DATABASE_URL=postgresql://tm:tm@localhost:55432/transport_matters
# TRANSPORT_MATTERS_TEST_DATABASE_URL=postgresql://tm:tm@localhost:55432/postgres
