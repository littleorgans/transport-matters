set shell := ["bash", "-cu"]

# Default the test-DB URL so `just test`/`just ci` work against the local docker
# Postgres (`docker compose up -d`) without per-shell env setup. An exported
# TRANSPORT_MATTERS_TEST_DATABASE_URL still wins (CI sets its own, off :55432).
# The app itself stays loud when unconfigured; this is dev-workflow only.
export TRANSPORT_MATTERS_TEST_DATABASE_URL := env_var_or_default("TRANSPORT_MATTERS_TEST_DATABASE_URL", "postgresql://tm:tm@localhost:55432/postgres")

# Default task
default: check test

# ------------- Setup -------------

install:
    uv sync --all-extras --dev

# ------------- Dev -------------
dev:
    uv run python -m transport_matters

[no-exit-message]
proxy:
    uv run mitmdump --mode reverse:https://api.anthropic.com --listen-port 8787 -s src/transport_matters/addon.py

[no-exit-message]
spike:
    uv run mitmdump --mode reverse:https://api.anthropic.com --listen-port 8787 -s spike.py

# ------------- Build & Test -------------

test *args:
    uv run python -m pytest {{args}}

migration-smoke:
    uv run python -m pytest src/transport_matters/session/test_migrate.py -q

coverage:
    uv run python -m pytest --cov=transport_matters --cov-report=term-missing --cov-report=html

# Build wheel + sdist into api/dist/. Run `cd ../www && pnpm build` first
# if you want the frontend bundle inside the wheel; vite writes it to
# src/transport_matters/www/ which hatch includes via the artifacts glob.
build:
    rm -rf dist/
    uv build
    @echo ""
    @echo "Built artifacts:"
    @ls -lh dist/
    @echo ""
    @if unzip -l dist/transport_matters-*.whl | grep -q 'transport_matters/www/index.html'; then \
        echo "  ✓ www/ bundle embedded in wheel"; \
    else \
        echo "  ! www/ bundle NOT in wheel; run 'cd ../www && pnpm build' first"; \
    fi

# ------------- Quality Gates -------------

typecheck:
    uv run mypy src/

lint:
    uv run ruff check src/ --fix

format:
    uv run ruff format src/

check: format lint typecheck

# CI mode: no auto-fixing, fail on issues
ci:
    uv run ruff format --check src/
    uv run ruff check src/
    uv run mypy src/
    just migration-smoke
    uv run python -m pytest

# ------------- Maintenance -------------

clean:
    rm -rf __pycache__ .pytest_cache .ruff_cache .mypy_cache htmlcov .coverage *.egg-info build dist
    find . -type d -name __pycache__ -exec rm -rf {} + 2>/dev/null || true
