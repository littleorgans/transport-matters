{
  "compilerOptions": {
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "esModuleInterop": true,
    "lib": ["ES2023", "DOM"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "target": "ES2023",
    "types": ["node", "vitest/globals"],
    "verbatimModuleSyntax": true
  },
  "include": [
    "src/backendHealth.ts",
    "src/backendProcess.ts",
    "src/main.ts",
    "src/preload.ts",
    "src/window.ts"
  ]
}
