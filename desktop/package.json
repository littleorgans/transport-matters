{
  "name": "transport-matters-desktop",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "dist/main.js",
  "packageManager": "pnpm@10.8.1",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/assert-preload-cjs.mjs",
    "clean": "rimraf dist node_modules pnpm-lock.yaml",
    "dev": "pnpm build && pnpm electron:install && electron .",
    "electron:install": "node node_modules/electron/install.js",
    "package:smoke": "pnpm build && pnpm electron:install && electron-packager . \"Transport Matters\" --out dist/package-smoke --overwrite --no-prune && node dist/packageSmoke.js",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.test.json --noEmit"
  },
  "dependencies": {
    "electron": "^39.2.6"
  },
  "devDependencies": {
    "@electron/packager": "^19.0.0",
    "@types/node": "^25.6.0",
    "rimraf": "^6.1.3",
    "typescript": "^5.9.3",
    "vitest": "^4.1.4"
  }
}
