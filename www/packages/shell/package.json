{
  "name": "@tm/shell",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "clean": "rimraf dist node_modules",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test --project=chromium --project=firefox --project=webkit",
    "test:e2e:ui": "playwright test --project=chromium --project=firefox --project=webkit --ui",
    "test:visual": "playwright test --project=visual",
    "test:visual:update": "playwright test --project=visual --update-snapshots",
    "test:visual:ui": "playwright test --project=visual --ui",
    "lint": "biome check . ../host ../core ../inspector ../canvas",
    "lint:fix": "biome check --write . ../host ../core ../inspector ../canvas",
    "format": "biome format --write . ../host ../core ../inspector ../canvas",
    "typecheck": "tsc -b --noEmit"
  },
  "dependencies": {
    "@ark-ui/react": "^5.37.2",
    "@dnd-kit/core": "6.3.1",
    "@dnd-kit/sortable": "10.0.0",
    "@dnd-kit/utilities": "3.2.2",
    "@tanstack/react-query": "^5.97.0",
    "@tanstack/react-virtual": "^3.13.23",
    "@use-gesture/react": "^10.3.1",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "diff": "^9.0.0",
    "framer-motion": "^12.40.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tinykeys": "^4.0.0",
    "zustand": "^5.0.12"
  }
}
